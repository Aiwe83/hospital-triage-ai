# ============================================================
# hospital-triage-ai — environment variables (example)
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# -------- LLM (NextAI / OpenAI-compatible proxy) --------
LLM_API_KEY=
LLM_BASE_URL=https://your-openai-compatible-proxy.example.com/v1
LLM_MODEL=gpt-5-chat-nextai
LLM_USER_EMAIL=
LLM_TIMEOUT=60
LLM_PROVIDER=AzureOpenAI
LLM_ORIGIN=hospital-triage-ai
LLM_ORIGIN_DETAIL=backend

# -------- MongoDB --------
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=hospital_triage

# -------- Elasticsearch --------
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX_PROTOCOLS=hospital_protocols

# -------- MCP server --------
MCP_SERVER_URL=http://mcp-server:7800
MCP_ENABLED=true
MCP_DRIVE_TIMEOUT=60

# -------- Report export --------
REPORT_EXPORT_MODE=mock
REPORT_OUTPUT_DIR=/app/reports
REPORT_RECIPIENT_EMAIL=

# -------- Drive integration (no Google API) --------
# The MCP server `send_report_to_drive` tool copies the medical PDF
# into this folder. Google Drive Desktop, installed on Windows, syncs
# that folder to Google Drive automatically. No OAuth, no service
# account, no API credentials.
#
# Inside Docker the MCP server reads the path /app/reports (set in
# infra/docker-compose.yml) which is bind-mounted to the host path
# below. Adjust to match your local Drive Desktop layout.
DRIVE_SYNC_FOLDER=C:\path\to\your\Google Drive synced folder

# -------- Backend --------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# -------- Frontend (Next.js) --------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SSE_URL=http://localhost:8000

# -------- Jira integration (optional) --------
# Each triage case becomes a Jira ticket in JIRA_PROJECT_KEY. Comments are
# added when the report is ready and when the PDF is delivered. The button
# "Cerrar caso" in the UI transitions the ticket to DONE.
#
# Set JIRA_ENABLED=true ONLY after running:
#   docker exec htai-backend python -m scripts.jira_discover
# which prints the real issuetype name, transition IDs and your accountId.
# Copy those values below so the integration does not have to guess.
JIRA_ENABLED=false
JIRA_URL=https://pablodefranchi.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=KAN
# Defaults match Atlassian Cloud "Basic Kanban" templates; override after
# running jira_discover.py if your board uses different names/IDs.
JIRA_ISSUETYPE_NAME=Task
JIRA_TRANSITION_ID_IN_PROGRESS=
JIRA_TRANSITION_ID_DONE=
JIRA_LABELS=paciente,triage-ia,hospital-ai
JIRA_TIMEOUT=15
